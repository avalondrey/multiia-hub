  "icons": [
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "/icon.svg",     "sizes": "any",      "type": "image/svg+xml" }
  ],
  "screenshots": [
    {
      "src": "/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Chat multi-IA sur mobile"
    },
    {
      "src": "/screenshot-wide.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Multi-IA Hub sur desktop"
    }
  ],
  "shortcuts": [
    { "name": "◈ Chat IA",      "short_name": "Chat",      "url": "/?tab=chat",      "icons": [{"src": "/icon-192.png", "sizes": "192x192"}] },
    { "name": "✍️ Rédaction",    "short_name": "Rédaction", "url": "/?tab=redaction", "icons": [{"src": "/icon-192.png", "sizes": "192x192"}] },
    { "name": "📋 Prompts",      "short_name": "Prompts",   "url": "/?tab=prompts",   "icons": [{"src": "/icon-192.png", "sizes": "192x192"}] },
    { "name": "🎬 Médias",       "short_name": "Médias",    "url": "/?tab=medias",    "icons": [{"src": "/icon-192.png", "sizes": "192x192"}] }
  ],
  "protocol_handlers": [],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
