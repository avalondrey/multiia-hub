# MULTI-IA HUB — .gitignore
# -------------------------

# ⚠️ SÉCURITÉ - Données sensibles (NOUVEAU)
# Données chiffrées et IndexedDB
*.enc
*.encrypted
*.key
*.pem
*.crt
secrets/
keys.json
api-keys.json
credentials.json
multiia-keys.json
multiia-backup-*.json

# Build Vite / React
dist/
build/
.vercel/

# Dépendances
node_modules/
.pnpm-store/

# Variables d'environnement
.env
.env.local
.env.*.local
relay_config.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Système
.DS_Store
Thumbs.db
Desktop.ini

# IDE / outils locaux
.vscode/
.idea/
.claude/
.continue/

# Scripts de build/debug locaux
transform-app.mjs
fix-bugs.js
fix-jsx.js
fix_*.py
patch_*.py
patch-*.mjs
debug-*.js
debug-*.txt
check.js
check_*.py
check-*.js
analyze.py
audit_*.py
verify_*.py
show_*.py
find_*.py
inject_*.py
resize_*.js
capture_*.js
preview.js
generate-app.mjs
build-html.mjs
cli_relay.py
extracted-data.json
tuto_output.kdenlive

# Backups App.jsx
src/App.jsx.bak
src/App.jsx.clean
src/App.jsx.182
src/App.jsx.212
src/App.jsx.backup
*.backup
*.bak
*.old

# Fichiers temp à la racine
app-new.html
app-new2.html
new_styles.css
new-app-styles.js
preview_*.jpg
debug-out.txt

# PowerShell scripts (locaux)
*.ps1

# Shell scripts (sauf deploy-cloudflare.sh qui est utile)
*.sh
!deploy-cloudflare.sh

# Documentation temporaire
*.md.tmp
*.md.bak

# Coverage / tests
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/

# Wrangler (Cloudflare)
.wrangler/
.dev.vars
